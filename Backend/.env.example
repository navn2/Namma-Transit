# Supabase Postgres connection pooler string (transaction mode, port 6543)
# Get yours at https://supabase.com/dashboard/project/<ref>/settings/database
# Format: postgresql://<project-user>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=72
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
WEBPUSH_VAPID_PRIVATE_KEY=your_vapid_private_key
WEBPUSH_VAPID_PUBLIC_KEY=your_vapid_public_key
WEBPUSH_VAPID_EMAIL=mailto:team@nammatransit.app
ALLOWED_ORIGINS=http://localhost:3000,https://nammatransit.app
APP_NAME=Namma Transit API
ENABLE_SCHEDULER=true
